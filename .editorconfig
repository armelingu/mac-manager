# EditorConfig: keep editors aligned with the project conventions.
# https://editorconfig.org

root = true

# ---------------------------------------------------------------------
# Defaults: UTF-8, LF line endings, trim whitespace, ensure final newline.
# ---------------------------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# ---------------------------------------------------------------------
# Per-language overrides
# ---------------------------------------------------------------------

[*.py]
indent_size = 4
max_line_length = 100

[*.{yml,yaml}]
indent_size = 2

[*.{json,toml}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false  # Markdown uses two trailing spaces for line breaks.

[Makefile]
indent_style = tab

[*.{sh,bash,zsh}]
indent_size = 2

# Homebrew formula files (Ruby).
[*.rb]
indent_size = 2

[*.{plist,xml}]
indent_size = 4

# Generated lock files / vendored content shouldn't be reformatted.
[**/{dist,build,.venv}/**]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
indent_style = unset
indent_size = unset
